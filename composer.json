{
    "name": "amazingbv/statamic-gutenberg",
    "description": "Block editor addon for Statamic.",
    "license": "GPL-2.0-only",
    "autoload": {
        "psr-4": {
            "Amazingbv\\StatamicGutenberg\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amazingbv\\StatamicGutenberg\\Tests\\": "tests"
        }
    },
    "require": {
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.8"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Statamic Block Editor",
            "description": "Block editor addon for Statamic"
        },
        "laravel": {
            "providers": [
                "Amazingbv\\StatamicGutenberg\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
